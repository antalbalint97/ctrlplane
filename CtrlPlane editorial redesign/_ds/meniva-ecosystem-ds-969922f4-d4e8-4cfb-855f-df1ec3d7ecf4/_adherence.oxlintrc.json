{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": [
          {
            "element": "button",
            "message": "Use <Button> from the design system instead of <button>."
          }
        ]
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/Button/**",
              "components/brand/LogoLockup/**",
              "components/cards/ArticleCard/**",
              "components/cards/Card/**",
              "components/cards/CourseCard/**",
              "components/cards/ServiceCard/**",
              "components/forms/NewsletterSignup/**",
              "components/navigation/Footer/**",
              "components/navigation/Navbar/**",
              "components/sections/Hero/**",
              "components/sections/SectionHeader/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|Inter Tight|Inter|JetBrains Mono|Outfit|Unbounded))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, Inter Tight, Inter, JetBrains Mono, Outfit, Unbounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|excerpt|href|date|readingTime|category|image|cta|className|key|ref|className|style|children)$/]",
        "message": "<ArticleCard> doesn't accept that prop. Declared props: title, excerpt, href, date, readingTime, category, image, cta, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|leftIcon|rightIcon|className|children|id|style|href|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, leftIcon, rightIcon, className, children, id, style, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:link|primary|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'link' | 'primary' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|padding|interactive|as|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: className, id, style, children, padding, interactive, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CourseCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|level|description|topics|topicsLabel|meta|action|className|key|ref|className|style|children)$/]",
        "message": "<CourseCard> doesn't accept that prop. Declared props: title, level, description, topics, topicsLabel, meta, action, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|tagline|columns|social|copyright|bottomNote|container|className|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: logo, tagline, columns, social, copyright, bottomNote, container, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute[name.name='container'] > Literal[value!=/^(?:content|wide|marketing)$/]",
        "message": "<Footer> container must be one of 'content' | 'wide' | 'marketing'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:overline|title|description|primaryAction|secondaryAction|variant|align|media|stats|children|className|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: overline, title, description, primaryAction, secondaryAction, variant, align, media, stats, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:display|panel|split)$/]",
        "message": "<Hero> variant must be one of 'display' | 'panel' | 'split'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<Hero> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoLockup'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|wordmark|tagline|mark|iconOnly|href|size|className|key|ref|className|style|children)$/]",
        "message": "<LogoLockup> doesn't accept that prop. Declared props: brand, wordmark, tagline, mark, iconOnly, href, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoLockup'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<LogoLockup> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|items|action|sticky|container|className|key|ref|className|style|children)$/]",
        "message": "<Navbar> doesn't accept that prop. Declared props: logo, items, action, sticky, container, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute[name.name='container'] > Literal[value!=/^(?:content|wide|marketing)$/]",
        "message": "<Navbar> container must be one of 'content' | 'wide' | 'marketing'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsletterSignup'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|placeholder|buttonLabel|note|layout|successMessage|onSubmit|className|key|ref|className|style|children)$/]",
        "message": "<NewsletterSignup> doesn't accept that prop. Declared props: title, description, placeholder, buttonLabel, note, layout, successMessage, onSubmit, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsletterSignup'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:inline|stacked)$/]",
        "message": "<NewsletterSignup> layout must be one of 'inline' | 'stacked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:overline|title|description|align|as|actions|className|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: overline, title, description, align, as, actions, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeader> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:h1|h2|h3)$/]",
        "message": "<SectionHeader> as must be one of 'h1' | 'h2' | 'h3'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|features|action|interactive|className|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: icon, title, description, features, action, interactive, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ArticleCard": {
        "replaces": []
